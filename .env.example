# Voice Dictation — Environment Variables
# Copy to .env and configure

# Ollama (local model @ homelab)
OLLAMA_URL=http://192.168.1.5:11434/api/chat
OLLAMA_MODEL=qwen3.5:9b

# Whisper model size: tiny | base | small | medium | large-v3
# tiny/base = fast but less accurate; small = good balance; large-v3 = best quality
WHISPER_MODEL=small

# Anthropic (optional, for cloud mode)
# ANTHROPIC_API_KEY=sk-ant-...
